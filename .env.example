# Copy to .env at repo root (never commit .env)
#   cp .env.example .env
#
# Full reference: docs/HANDOVER.md

NODE_ENV=development

# --- API (Fastify) ---
API_PORT=4000
API_HOST=0.0.0.0

# Required. Min 32 characters or API refuses to start.
# Generate: openssl rand -base64 48
JWT_SECRET=replace_me_with_at_least_32_random_characters_local_dev_only

# --- PostgreSQL (local Docker — see docker-compose.yml) ---
# Runtime: workerai_app (RLS). Migrations: workerai_owner.
DATABASE_URL=postgresql://workerai_app:workerai_app_dev_local@localhost:5432/workerai
DATABASE_URL_MIGRATE=postgresql://workerai_owner:workerai_owner_dev_local@localhost:5432/workerai

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
